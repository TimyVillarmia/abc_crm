<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_abc_crm_multi_step_form" name="ABC CRM Multi-Step Form">
        <section class="s_abc_crm_multi_step_form pt64 pb64 o_cc o_cc1"
            data-snippet="s_abc_crm_multi_step_form">
            <div class="container">
                <form class="abc-crm-form" action="/abc_crm/website/lead" method="post"
                    novalidate="novalidate">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()" />
                    <input type="text" name="abc_crm_hp" class="abc-crm-hp" tabindex="-1"
                        autocomplete="off" aria-hidden="true" />
                    <input type="hidden" name="utm_source" value="Website" />
                    <input type="hidden" name="utm_medium" value="Website Form" />
                    <input type="hidden" name="utm_campaign" value="Website Inquiry" />

                    <div class="abc-crm-form__header">
                        <p class="abc-crm-form__eyebrow">Project inquiry</p>
                        <h2>Tell us about your project</h2>
                        <div class="abc-crm-form__progress" aria-hidden="true">
                            <span class="abc-crm-form__progress-bar" />
                        </div>
                    </div>

                    <div class="abc-crm-form__alert alert d-none" role="status" />

                    <div class="abc-crm-form__step" data-step="0">
                        <h3>Contact</h3>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label" for="abc_crm_contact_name">Contact name</label>
                                <input id="abc_crm_contact_name" class="form-control" type="text"
                                    name="contact_name" required="required" autocomplete="name" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="abc_crm_partner_name">Company</label>
                                <input id="abc_crm_partner_name" class="form-control" type="text"
                                    name="partner_name" required="required"
                                    autocomplete="organization" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="abc_crm_email_from">Email</label>
                                <input id="abc_crm_email_from" class="form-control" type="email"
                                    name="email_from" required="required" autocomplete="email" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="abc_crm_phone">Phone</label>
                                <input id="abc_crm_phone" class="form-control" type="tel"
                                    name="phone" required="required" autocomplete="tel" />
                            </div>
                            <div class="col-12">
                                <label class="form-label" for="abc_crm_message">Inquiry</label>
                                <textarea id="abc_crm_message" class="form-control" name="message"
                                    required="required" rows="4"></textarea>
                            </div>
                        </div>
                    </div>

                    <div class="abc-crm-form__step d-none" data-step="1">
                        <h3>Project</h3>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label" for="abc_crm_project_name">Project name</label>
                                <input id="abc_crm_project_name" class="form-control" type="text"
                                    name="project_name" required="required" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="abc_crm_project_type">Project type</label>
                                <input id="abc_crm_project_type" class="form-control" type="text"
                                    name="project_type" required="required" />
                            </div>
                            <div class="col-12">
                                <label class="form-label" for="abc_crm_project_location">Project
                                    location</label>
                                <input id="abc_crm_project_location" class="form-control"
                                    type="text" name="project_location" required="required" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label" for="abc_crm_company_type">Company type</label>
                                <select id="abc_crm_company_type" class="form-select"
                                    name="company_type" required="required">
                                    <option value="">Select one</option>
                                    <option value="contractor">Contractor</option>
                                    <option value="developer">Developer</option>
                                    <option value="homeowner">Homeowner</option>
                                    <option value="architect">Architect</option>
                                    <option value="trader">Trader</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label" for="abc_crm_estimated_project_value">Estimated
                                    value</label>
                                <input id="abc_crm_estimated_project_value" class="form-control"
                                    type="number" name="estimated_project_value" min="0" step="0.01" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label" for="abc_crm_target_completion_date">Target
                                    completion</label>
                                <input id="abc_crm_target_completion_date" class="form-control"
                                    type="date" name="target_completion_date" />
                            </div>
                        </div>
                    </div>

                    <div class="abc-crm-form__step d-none" data-step="2">
                        <h3>Qualification</h3>
                        <div class="abc-crm-form__criteria">
                            <div class="abc-crm-form__criterion">
                                <span>Project is five storeys or higher</span>
                                <div>
                                    <label><input type="radio" name="is_five_storey_up" value="yes"
                                            required="required" /> Yes</label>
                                    <label><input type="radio" name="is_five_storey_up" value="no"
                                            required="required" /> No</label>
                                </div>
                            </div>
                            <div class="abc-crm-form__criterion">
                                <span>Project is ongoing</span>
                                <div>
                                    <label><input type="radio" name="is_ongoing" value="yes"
                                            required="required" /> Yes</label>
                                    <label><input type="radio" name="is_ongoing" value="no"
                                            required="required" /> No</label>
                                </div>
                            </div>
                            <div class="abc-crm-form__criterion">
                                <span>Client is an AAC user</span>
                                <div>
                                    <label><input type="radio" name="is_aac_user" value="yes"
                                            required="required" /> Yes</label>
                                    <label><input type="radio" name="is_aac_user" value="no"
                                            required="required" /> No</label>
                                </div>
                            </div>
                            <div class="abc-crm-form__criterion">
                                <span>Client is open to innovative products</span>
                                <div>
                                    <label><input type="radio" name="is_open" value="yes"
                                            required="required" /> Yes</label>
                                    <label><input type="radio" name="is_open" value="no"
                                            required="required" /> No</label>
                                </div>
                            </div>
                            <div class="abc-crm-form__criterion">
                                <span>Client has AAC needs</span>
                                <div>
                                    <label><input type="radio" name="has_aac_needs" value="yes"
                                            required="required" /> Yes</label>
                                    <label><input type="radio" name="has_aac_needs" value="no"
                                            required="required" /> No</label>
                                </div>
                            </div>
                            <div class="abc-crm-form__criterion">
                                <span>Project has design specifications</span>
                                <div>
                                    <label><input type="radio" name="has_design_specifications"
                                            value="yes" required="required" /> Yes</label>
                                    <label><input type="radio" name="has_design_specifications"
                                            value="no" required="required" /> No</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="abc-crm-form__step d-none" data-step="3">
                        <h3>Review</h3>
                        <dl class="abc-crm-form__review">
                            <div>
                                <dt>Contact</dt>
                                <dd data-review="contact_name" />
                            </div>
                            <div>
                                <dt>Company</dt>
                                <dd data-review="partner_name" />
                            </div>
                            <div>
                                <dt>Project</dt>
                                <dd data-review="project_name" />
                            </div>
                            <div>
                                <dt>Location</dt>
                                <dd data-review="project_location" />
                            </div>
                            <div>
                                <dt>Project type</dt>
                                <dd data-review="project_type" />
                            </div>
                            <div>
                                <dt>Company type</dt>
                                <dd data-review="company_type" />
                            </div>
                        </dl>
                    </div>

                    <div class="abc-crm-form__actions">
                        <button type="button" class="btn btn-secondary abc-crm-form__back d-none">
                            Back</button>
                        <button type="button" class="btn btn-primary abc-crm-form__next">Next</button>
                        <button type="submit" class="btn btn-primary abc-crm-form__submit d-none">
                            Submit</button>
                    </div>
                </form>
            </div>
        </section>
    </template>

    <template id="abc_crm_snippets" inherit_id="website.snippets">
        <xpath expr="//snippets[@id='snippet_structure']" position="inside">
            <t t-snippet="abc_crm.s_abc_crm_multi_step_form"
                string="ABC CRM Multi-Step Form"
                group="contact_and_forms"
                t-thumbnail="/website/static/src/img/snippets_thumbs/s_website_form.svg"
                t-forbid-sanitize="form" />
        </xpath>
    </template>
</odoo>
