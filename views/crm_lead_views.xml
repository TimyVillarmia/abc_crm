<?xml version="1.0"?>
<odoo>
    <record id="crm_lead_view_form" model="ir.ui.view">
        <field name="name">crm.lead.form</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form" />
        <field name="arch" type="xml">
            <field name="state_id" position="replace">
                <field name="region_id" placeholder="Region" />
            </field>
            <field name="team_id" position="after"> 
                <field name="allowed_user_ids" invisible="1"/>
                <field name="is_view_restricted" invisible="1"/>
            </field>
            <xpath expr="(//field[@name='user_id'])[1]" position="before">
                <field name="team_id"/> 
            </xpath>
            <xpath expr="(//field[@name='user_id'])[2]" position="attributes">
                <attribute name="invisible">type != 'opportunity'</attribute>
            </xpath>
            <xpath expr="(//field[@name='user_id'])[1]" position="attributes">
                <attribute name="domain">[('id', 'in', allowed_user_ids)]</attribute>
                <attribute name="readonly">is_view_restricted or not team_id</attribute>
            </xpath>

            <xpath expr="(//field[@name='team_id'])[1]" position="attributes">
                <attribute name="readonly">is_view_restricted</attribute>
            </xpath>

            <xpath expr="(//field[@name='team_id'])[2]" position="attributes">
                <attribute name="domain">[('id', 'in', allowed_user_ids)]</attribute>
                <attribute name="invisible">type != 'opportunity'</attribute>
                <attribute name="readonly">is_view_restricted</attribute>
            </xpath>
            <xpath expr="//group[@name='Misc']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//page[@name='internal_notes']" position="before">
                <page string="Qualification Sheet">
                    <group string="Qualification Sheet" col="1">
                        <group col="1">
                            <div class="mt16">
                                <table class="table w-100 table-bordered ">
                                    <thead>
                                        <tr>
                                            <th style="width: 30%;">Criteria</th>
                                            <th style="width: 50%;">Specific Metric</th>
                                            <th style="width: 10%;" class="text-center">Y/N</th>
                                            <th style="width: 10%;" class="text-center">Weight</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>is Five Storey Up</td>
                                            <td>Project is 5 storey and above</td>
                                            <td class="text-center">
                                                <field nolabel="1" name="is_five_storey_up" />
                                            </td>
                                            <td class="text-center">15</td>
                                        </tr>
                                        <tr>
                                            <td>is Ongoing</td>
                                            <td>Project is undergoing construction</td>
                                            <td class="text-center">
                                                <field nolabel="1" name="is_ongoing" />
                                            </td>
                                            <td class="text-center">25</td>
                                        </tr>
                                        <tr>
                                            <td>is Open</td>
                                            <td>Client is open to innovative products like
                                                lightstrong</td>
                                            <td class="text-center">
                                                <field nolabel="1" name="is_open" />
                                            </td>
                                            <td class="text-center">10</td>
                                        </tr>
                                        <tr>
                                            <td>is AAC user</td>
                                            <td>Client is an AAC user</td>
                                            <td class="text-center">
                                                <field nolabel="1" name="is_aac_user" />
                                            </td>
                                            <td class="text-center">10</td>
                                        </tr>
                                        <tr>
                                            <td>has AAC Needs</td>
                                            <td>Client has requirement for faster construction,
                                                structural load reduction, or sustainable building
                                                systems</td>
                                            <td class="text-center">
                                                <field nolabel="1" name="has_aac_needs" />
                                            </td>
                                            <td class="text-center">15</td>
                                        </tr>
                                        <tr>
                                            <td>has Design Specification</td>
                                            <td>Project plan is written in specifications/plans by
                                                Designer</td>
                                            <td class="text-center">
                                                <field nolabel="1" name="has_design_specifications" />
                                            </td>
                                            <td class="text-center">25</td>
                                        </tr>
                                        <tr class="fw-bold">
                                            <td colspan="3">Total Rating</td>
                                            <td class="text-center">
                                                <field nolabel="1" name="rating" />
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </group>
                    </group>
                </page>
            </xpath>
            <xpath expr="//page[@name='internal_notes']" position="before">
                <page string="Client Information Sheet">
                    <group string="Client Information Sheet">
                        <group>
                            <field name="partner_name" />
                            <field name="company_type" />
                            <field name="project_name" />
                            <field name="project_location" />
                            <field name="project_type" />
                            <field name="estimated_project_value" />
                            <field name="target_completion_date" />
                        </group>
                        <group>
                            <field name="partner_id" />
                            <field name="contact_name" />
                            <field name="email_from" />
                            <field name="email_cc" />
                            <field name="function" />
                            <field name="phone" />
                            <field name="website" />
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
